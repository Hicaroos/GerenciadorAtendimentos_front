// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           Int     @id @default(autoincrement())
  name         String
  role         UserRole
  disciplines  ProfessorDiscipline

  appointmentsFromStudent    Appointment[] @relation("student_appointments")
  appointmentsFromProfessor  Appointment[] @relation("professor_appointments")

  @@map("users")
}

model Appointment {
  id           Int         @id @default(autoincrement())
  studentId    Int         @map("student_id")
  professorId  Int         @map("professor_id")
  startHour    DateTime    @map("start_hours")
  endHour      DateTime    @map("end_hours")
  status       AppointmentStatus  @default(PENDING)

  student      User @relation("student_appointments"   , fields: [studentId]   , references: [id])
  professor    User @relation("professor_appointments" , fields: [professorId] , references: [id])

  @@map("appointments")
}

enum UserRole {
  STUNDENT
  PROFESSOR
}

enum AppointmentStatus {
  CONFIRMED
  CANCELED
  PENDING
}

enum ProfessorDiscipline {
  PORTUGUESE
  MATH
  GEOGRAPHY
  CHEMISTRY
  BIOLOGIY
  LITERATURE
}
